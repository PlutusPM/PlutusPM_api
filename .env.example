# Supabase - Get from https://supabase.com/dashboard > Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...anon
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...service_role (SECRET)

# Local dev (supabase start outputs these)
# SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# OAuth providers (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# External services for Edge Functions
RESEND_API_KEY=re_... # for emails (visitor passes, compliance alerts)
SLACK_WEBHOOK_URL=https://hooks.slack.com/...
STRIPE_SECRET_KEY=sk_test_...

# Set secrets for cloud functions via CLI:
# supabase secrets set RESEND_API_KEY=re_xxx --project-ref your-project-id
